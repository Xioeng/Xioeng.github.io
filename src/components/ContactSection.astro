---
import { siteConfig } from "../config/site";
import "../styles/contact.css";
---

<section id="contact" class="contact-section">
  <div class="contact-container page-content">
    <div class="contact-header contact-header-animate">
      <h2 class="contact-title">{siteConfig.contact.title}</h2>
      <p class="contact-subtitle">
        {siteConfig.contact.subtitle}
      </p>
    </div>

    <div class="contact-grid">
      <!-- Contact Info Card -->
      <div class="contact-card contact-card-animate">
        <h3 class="contact-card-title">Contact Info</h3>
        <div class="contact-info-list">
          <div class="contact-info-item">
            <div class="contact-icon-wrapper email-icon">
              <img src="/svg/email.svg" alt="email icon" class="contact-icon" />
            </div>
            <div class="contact-info-content">
              <div class="contact-info-label">{siteConfig.contact.info.email.label}</div>
              <a href={siteConfig.contact.info.email.link} class="contact-info-value">{siteConfig.contact.info.email.value}</a>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-icon-wrapper phone-icon">
              <img src="/svg/phone.svg" alt="phone icon" class="contact-icon" />
            </div>
            <div class="contact-info-content">
              <div class="contact-info-label">{siteConfig.contact.info.phone.label}</div>
              <a href={siteConfig.contact.info.phone.link} class="contact-info-value">{siteConfig.contact.info.phone.value}</a>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-icon-wrapper location-icon">
              <img src="/svg/location.svg" alt="location icon" class="contact-icon" />
            </div>
            <div class="contact-info-content">
              <div class="contact-info-label">{siteConfig.contact.info.location.label}</div>
              <div class="contact-info-value">{siteConfig.contact.info.location.value}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Follow Me Card -->
      <div class="contact-card contact-card-animate">
        <h3 class="contact-card-subtitle">{siteConfig.contact.followMe.title}</h3>
        <div class="social-icons-list">
          {siteConfig.contact.followMe.links.map((social) => (
            <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-icon-link" title={social.name.toLowerCase()}>
              <img src={social.icon} alt={`${social.name} icon`} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="contact-footer-text comments-content-animate">
      {siteConfig.contact.footerText.map((text) => (
        <p>{text}</p>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .contact-section {
    padding: 80px 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .contact-container {
    max-width: 1000px;
    margin: 0 auto;
  }
</style>
